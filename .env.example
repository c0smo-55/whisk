# Without any key the app runs in demo mode (built-in recipe pools).
# Configure ONE of the options below for live AI generation.

# Option A — free & open-source models via Groq (recommended to start):
#   1. Sign up at https://console.groq.com (free, no credit card)
#   2. Create a key at https://console.groq.com/keys
LLM_API_KEY=
# Optional overrides — defaults are Groq + Llama 3.3 70B. The same two vars
# point the app at any OpenAI-compatible API (DeepSeek, OpenRouter, Ollama…):
#   DeepSeek:   LLM_BASE_URL=https://api.deepseek.com  LLM_MODEL=deepseek-chat
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1  LLM_MODEL=<any model id>
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# Option B — Claude (paid, highest quality; takes priority if both are set):
ANTHROPIC_API_KEY=
